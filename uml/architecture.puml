@startuml
left to right direction
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam backgroundColor white

skinparam node {
  BackgroundColor #F8F9FA
  BorderColor #343A40
}
skinparam database {
  BackgroundColor #E9ECEF
  BorderColor #343A40
}
skinparam package {
  BackgroundColor #FFFFFF
  BorderColor #6C757D
}
skinparam component {
  BackgroundColor #E3F2FD
  BorderColor #0D6EFD
  ArrowColor #0D6EFD
}

node "Client Browser" {
  [Blade Views (HTML/CSS/JS)] as views
}

node "Laravel Web Server (Apache/Nginx)" {
  [Routes (web.php, api.php)] as routes
  
  package "Controllers" as Controllers {
    [ProductController]
    [OrderController]
    [CartController]
    [UserController]
    [Api\\ProductController]
    [Api\\AuthController]
  }

  package "Models (Eloquent ORM)" as Models {
    [User]
    [Product]
    [Category]
    [Order]
    [OrderItem]
  }
}

database "MySQL Database" {
  [Tables]
}

views --> routes : HTTP Request (GET/POST/PUT/DELETE)
routes --> Controllers : Route to Action
Controllers --> Models : Data Manipulation (CRUD)
Models --> [Tables] : SQL Queries
Controllers --> views : Return View with Data
[Api\\ProductController] --> Models : API Requests
[Api\\ProductController] --> views : Return JSON Response

@enduml
